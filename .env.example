# Copy to .env and adjust for your environment.
# All settings are optional; defaults are shown in src/neuroembed/config.py.

NEUROEMBED_LOG_LEVEL=INFO
NEUROEMBED_MODEL_ID=brain-bzh/reve-base
NEUROEMBED_POSITION_BANK_ID=brain-bzh/reve-positions
# Get a token at https://huggingface.co/settings/tokens
# Required because REVE is a gated model.
NEUROEMBED_HF_TOKEN=
NEUROEMBED_CORS_ORIGINS=
NEUROEMBED_CACHE_DIR=/tmp/neuroembed-cache
